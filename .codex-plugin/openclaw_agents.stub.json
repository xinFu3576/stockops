        "stockops-adapt",
        "stockops-watch",
        "stockops-paper",
        "stockops-learn",
        "stockops-dashboard",
        "stockops-llm"
      ],
      "model": {
        "primary": "openai/gpt-5.5",
        "fallbacks": [
          "volcengine-plan/ark-code-latest",
          "openrouter/free",
          "google/gemini-3.1-pro-preview"
        ]
      }
    },
