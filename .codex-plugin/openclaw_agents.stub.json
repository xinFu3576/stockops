{
  "agents": [
    {
      "id": "stockops_operator",
      "name": "股票交易 Operator",
      "workspace": "{{HOME}}/.openclaw/workspace/workspaces/stockops/00_stockops_operator",
      "agentDir": "{{HOME}}/.openclaw/workspace/agents/stockops_operator/agent",
      "sandbox": {
        "mode": "all",
        "scope": "agent",
        "workspaceAccess": "rw"
      },
      "tools": {
        "allow": [
          "read",
          "write",
          "edit",
          "sessions_list",
          "sessions_history",
          "sessions_send",
          "session_status",
          "sandbox_exec",
          "sandbox_process"
        ],
        "deny": [
          "message",
          "exec",
          "process"
        ]
      },
      "heartbeat": {
        "every": "4h",
        "target": "last",
        "includeSystemPromptSection": true,
        "prompt": "Heartbeat: 若当前时段属于交易日 09:00-10:30 或 17:30-19:00,先跑一次 daily.sh(见 stockops-cron),把 reports/alert_*.md 摘要上报 main;若已跑过或非交易时段,只做 inbox 巡检,静默即可。"
      },
      "skills": [
        "stockops-shared",
        "stockops-pipeline",
        "stockops-verify",
        "stockops-reflect",
        "dispatching-parallel-agents",
        "executing-plans",
        "writing-plans",
        "taskflow",
        "taskflow-inbox-triage",
        "main-agent-chief-of-staff",
        "session-logs",
        "verification-before-completion",
        "stockops-batch",
