{
  "name": "stockops",
  "version": "0.7.0",
  "description": "StockOps v0.7.0: 8 agents · 18 skills · 4 broker · 6 层数据兜底 · 6 微结构因子 · 7 源投资情报聚合(new: investment-news) · 4 推送渠道(飞书+企业微信+Server 酱+SMTP) · Dashboard 5 视图(K 线/网格/回测/P&L/情报) · GitHub Actions 自动 Release · brew tap · 14/14 tests",
  "author": "sendy",
  "skills_dir": "skills",
  "python": {
    "root": ".",
    "venv": ".venv",
    "requirements": "requirements.txt",
    "min_version": "3.11"
  },
  "entrypoints": [
    {
      "name": "daily",
      "cmd": "./daily.sh",
      "description": "一键日跑"
    },
    {
      "name": "pipeline",
      "cmd": "python -m core.orchestrator",
      "description": "单日决策"
    },
    {
      "name": "batch",
      "cmd": "python -m tools.batch_runner",
      "description": "watchlist 批处理"
    },
    {
      "name": "backtest",
      "cmd": "python -m tools.backtest_cli",
      "description": "向量化回测"
    },
    {
      "name": "grid",
      "cmd": "python -m tools.grid_search",
      "description": "参数网格"
    },
    {
      "name": "verify",
      "cmd": "python -m tools.verify",
      "description": "健康检查"
    },
    {
      "name": "reflect",
      "cmd": "python -m tools.reflect",
      "description": "回填 realized"
    },
    {
      "name": "adapt",
      "cmd": "python -m tools.adapt",
      "description": "闭环学习:更新权重"
    },
    {
      "name": "watch",
      "cmd": "python -m tools.price_watch",
      "description": "分钟级价格预警"
    },
    {
      "name": "notify",
      "cmd": "python -m tools.notify",
      "description": "飞书/邮件推送"
    },
    {
      "name": "learn",
      "cmd": "python -m tools.learn",
      "description": "reflect + adapt 一体化"
    },
    {
      "name": "manage",
      "cmd": "./manage.py",
      "description": "统一入口(decide/watch/paper-status/...)"
    },
    {
      "name": "test",
      "cmd": "python -m pytest tests/",
      "description": "跑单测"
    },
    {
      "name": "dashboard",
      "cmd": "python -m dashboard.server",
      "description": "零依赖 Web 仪表盘 (8765)"
    },
    {
      "name": "broker-health",
      "cmd": "./manage.py broker-health",
      "description": "诊断 4 家 broker 连通性"
    },
    {
      "name": "investment-news",
      "cmd": "python -m tools.investment_news",
      "description": "投资情报聚合(7 源)"
    }
  ],
  "openclaw": {
    "agents_config_stub": "openclaw_agents.stub.json",
    "workspace_charter_dir": "openclaw_workspaces"
  },
  "docs": [
    "README.md",
    "docs/"
  ]
}