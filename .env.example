# ==== LLM 配置 (OpenAI 兼容协议) ====
# 留空则全部走启发式兜底 (仍可正常跑 pipeline)

# 官方 OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxxx
# DEEP_LLM=gpt-4o
# QUICK_LLM=gpt-4o-mini

# DeepSeek
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-xxxx
# DEEP_LLM=deepseek-chat
# QUICK_LLM=deepseek-chat

# 本地 vLLM / Ollama (OpenAI 兼容)
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=EMPTY
# DEEP_LLM=Qwen/Qwen2.5-72B-Instruct
# QUICK_LLM=Qwen/Qwen2.5-7B-Instruct

LLM_TIMEOUT_S=40
LLM_MAX_RETRIES=2

# ==== 数据源代理 ====
# 已通过 shell 环境的 HTTPS_PROXY / SOCKS5_PROXY 生效，不必在此重复

# ==== v0.16 · 多提供商 fallback 链 ====
# Primary: OpenAI GPT (留空则跳过 → 直接用 fallback)
# OPENAI_API_KEY=sk-your-openai-key
# DEEP_LLM=gpt-4o
# QUICK_LLM=gpt-4o-mini

# Fallback1: 火山方舟 deepseek-v4-pro
# Fallback2: 火山方舟 deepseek-v4-flash  (共享 ARK_API_KEY)
# ARK_API_KEY=sk-your-ark-key
# ARK_DEEP_MODEL=deepseek-v4-pro
# ARK_QUICK_MODEL=deepseek-v4-flash
